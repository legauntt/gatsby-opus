# Copy to .env and fill in. Only PUBLIC_BACKEND_BASE_URL is required.
# All PUBLIC_* vars are baked into the client bundle at build time.

# Backend for /wtc + garden presets (glawskis)
PUBLIC_BACKEND_BASE_URL=

# ---------------------------------------------------------------------------
# Butterfly Field cross-device multiplayer (Path A: bring your own TURN).
# Same-device (BroadcastChannel) and same-network P2P work with NOTHING set.
# To make cross-device reliable behind symmetric NATs/firewalls, add a TURN
# server below. Data is tiny (position sync), so relayed bandwidth is pennies.
# PUBLIC_TURN_URL may be a comma-separated list.
# ---------------------------------------------------------------------------

# --- Option 1: Cloudflare Realtime TURN (managed, ~$0.05/GB, generous free) ---
# Create a TURN app in the Cloudflare dashboard -> it gives you a URL + creds.
# PUBLIC_TURN_URL=turn:turn.cloudflare.com:3478,turns:turn.cloudflare.com:5349
# PUBLIC_TURN_USERNAME=<cloudflare turn key id>
# PUBLIC_TURN_CREDENTIAL=<cloudflare turn key>

# --- Option 2: Twilio Network Traversal (STUN free, TURN ~$0.40/GB) ---
# Mint short-lived creds via Twilio's Tokens API, or use static creds.
# PUBLIC_TURN_URL=turn:global.turn.twilio.com:3478?transport=udp
# PUBLIC_TURN_USERNAME=<twilio username>
# PUBLIC_TURN_CREDENTIAL=<twilio credential>

# --- Option 3: Metered.ca (free ~50GB/mo tier, then paid) ---
# PUBLIC_TURN_URL=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:443
# PUBLIC_TURN_USERNAME=<metered username>
# PUBLIC_TURN_CREDENTIAL=<metered credential>

# --- Option 4: Self-hosted coturn on a ~$5/mo VPS ---
# PUBLIC_TURN_URL=turn:your.vps.example:3478
# PUBLIC_TURN_USERNAME=<coturn user>
# PUBLIC_TURN_CREDENTIAL=<coturn password>

# Optional: self-hosted PeerServer for signaling (removes the free broker's
# rate limits; does NOT replace TURN). Leave unset to use PeerJS's free cloud.
# PUBLIC_PEER_HOST=your.vps.example
# PUBLIC_PEER_PORT=443
# PUBLIC_PEER_PATH=/
# PUBLIC_PEER_SECURE=true
